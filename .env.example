# 복사해서 .env 로 사용:  cp .env.example .env
#
# LIBRARY_DIR: 생성된 클립·내보내기(라이브러리)를 저장할 호스트 경로.
# 미설정 시 기본값은 ./workspace/output (레포 안, ext4).
# 용량 큰 별도 디스크에 두려면 절대경로로 지정. 예:
#   LIBRARY_DIR=/mnt/e/comfyui-library     # WSL2에서 Windows E: 드라이브
#   LIBRARY_DIR=/data/comfyui-library      # Linux 별도 마운트
# 주의: 이동식(USB) 드라이브는 분리 시 마운트가 깨지므로 권장하지 않음.
LIBRARY_DIR=./workspace/output
